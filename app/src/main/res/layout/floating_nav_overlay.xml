<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/floating_nav_overlay"
    android:layout_width="wrap_content"
    android:layout_height="60dp"
    android:layout_gravity="bottom|center_horizontal"
    android:layout_marginBottom="48dp"
    android:alpha="0"
    android:background="@drawable/floating_nav_bg"
    android:elevation="12dp"
    android:orientation="horizontal"
    android:visibility="invisible">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_nav_back"
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:background="@null"
        android:contentDescription="@string/action_back"
        android:padding="16dp"
        app:srcCompat="@drawable/ic_action_back"
        app:tint="#FFFFFFFF" />

    <View
        android:layout_width="1dp"
        android:layout_height="28dp"
        android:layout_gravity="center_vertical"
        android:background="#33FFFFFF" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_nav_forward"
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:background="@null"
        android:contentDescription="@string/action_forward"
        android:padding="16dp"
        app:srcCompat="@drawable/ic_action_forward"
        app:tint="#FFFFFFFF" />

</LinearLayout>
